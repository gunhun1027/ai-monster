# ===== 数据库 =====
# Neon PostgreSQL 连接字符串（注意：去掉 channel_binding=require，加上 connect_timeout=30）
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&connect_timeout=30"

# ===== 认证 =====
# JWT 密钥（至少32字符，生产环境请使用强随机字符串）
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# ===== 服务 =====
PORT=3000
CLIENT_URL=http://localhost:5173

# ===== AI出题（可选，未配置则使用演示模式）=====
# NVIDIA NIM（推荐，OpenAI兼容）
# AI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://integrate.api.nvidia.com/v1
# AI_MODEL=deepseek-ai/deepseek-v4-flash
#
# DeepSeek
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.deepseek.com/v1
